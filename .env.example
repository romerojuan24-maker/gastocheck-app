# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY   # solo backend / edge functions

# Móvil (Expo) — mismas claves con prefijo EXPO_PUBLIC
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# IA — Claude Vision (Edge Function /ocr-extract)
# Configura esto en tu Supabase project → Settings → Edge Functions secrets
ANTHROPIC_API_KEY=sk-ant-...

# WhatsApp Cloud API (Meta)
WHATSAPP_TOKEN=...
WHATSAPP_PHONE_NUMBER_ID=...

# Stripe (suscripciones)
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
