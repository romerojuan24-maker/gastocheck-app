{
  "name": "gastocheck",
  "version": "0.1.0",
  "private": true,
  "description": "GastoCheck — Control de anticipos, comprobaciones y saldos por persona.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "web": "npm run dev -w apps/web",
    "mobile": "npm run start -w apps/mobile",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "supabase": "^2.105.0"
  },
  "dependencies": {
    "@react-native-community/netinfo": "^12.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-native-web": "^0.21.2"
  }
}
