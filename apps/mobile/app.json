{
  "expo": {
    "name": "CHECK SUITE",
    "slug": "gastocheck",
    "scheme": "gastocheck",
    "version": "0.1.72",
    "runtimeVersion": "0.1.72",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#003DA5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gastocheck.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "CHECK SUITE usa tu ubicación para registrar la ruta de cobranza y ubicar a tus clientes.",
        "NSPhotoLibraryUsageDescription": "CHECK SUITE necesita acceso a tus fotos para adjuntar comprobantes.",
        "NSCameraUsageDescription": "CHECK SUITE necesita la cámara para capturar comprobantes y escanear códigos QR.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.gastocheck.app",
      "versionCode": 0,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "CHECK SUITE necesita acceso a tus fotos para adjuntar comprobantes."
        }
      ],
      "expo-document-picker",
      [
        "expo-camera",
        {
          "cameraPermission": "CHECK SUITE necesita la cámara para escanear códigos QR y capturar comprobantes."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "CHECK SUITE usa tu ubicación para registrar la ruta de cobranza y ubicar a tus clientes."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0057FF"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "11c09583-5e21-46ad-8116-a2e13994570e"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "juan.romero",
    "updates": {
      "url": "https://u.expo.dev/11c09583-5e21-46ad-8116-a2e13994570e"
    }
  }
}
