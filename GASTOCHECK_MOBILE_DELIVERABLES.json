  "architecture": {
    "main_component": "GastoCheckScreen (default export)",
    "sub_components": [
      "RouteList",
      "ClientDetail",
      "ScannerModal",
      "MovementForm",
      "ReportSummary"
    ],
    "hooks": [
      "useRoute",
      "useScanner",
      "useMovementCapture",
      "useDailyReport",
      "useMovementsByDate",
      "useCashDeposits"
    ],
    "external_libraries": [
      "React Native",
      "expo-location",
      "expo-image-picker",
      "expo-linking",
      "react-native-safe-area-context",
      "Anthropic Claude (Vision API)",
      "Google Maps (URL scheme)",
      "Supabase"
    ]
  },
  "database_schema": {
    "tables": [
      {
        "name": "daily_routes",
        "description": "Ruta optimizada diaria",
        "columns": [
          "id (UUID)",
          "company_id",
          "actor_id",
          "route_date",
          "client_id",
          "sequence (orden de visita)",
          "distance_km",
          "eta_minutes",
          "status (pending/visited/completed)"
        ]
      },
      {
        "name": "cobra_movements",
        "description": "Intentos de cobro en campo",
        "columns": [
          "id (UUID)",
          "client_id",
          "actor_id",
          "movement_date",
          "status (paid/unpaid/promise)",
          "amount (MXN)",
          "method (cash/transfer/check/card)",
          "unpaid_reason",
          "promise_date"
        ]
      },
      {
        "name": "cobra_daily_reports",
        "description": "Reporte diario para supervisor",
        "columns": [
          "id (UUID)",
          "actor_id",
          "report_date",
          "clients_visited",
          "total_collected",
          "promises_made",
          "cash_deposited"
        ]
      },
      {
        "name": "cobra_cash_deposits",
        "description": "Depósitos de efectivo realizados",
        "columns": [
          "id (UUID)",
          "actor_id",
          "amount (MXN)",
          "deposit_date",
          "reference (comprobante)",
          "verified (validado por supervisor)"
        ]
      }
    ]
  },
